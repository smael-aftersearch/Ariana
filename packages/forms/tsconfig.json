{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "baseUrl": "../..",
    "paths": {
      "@ariana-framework/core": ["packages/core/dist/index.d.ts"],
      "@ariana/core": ["packages/core/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../core" }
  ]
}
