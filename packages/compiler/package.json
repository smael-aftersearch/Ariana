{
  "name": "@ariana-framework/compiler",
  "version": "0.4.1",
  "description": "Ariana template parser, diagnostics, and compiler utilities.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
